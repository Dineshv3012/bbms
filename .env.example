# BBMS Environment Variables
# Copy this to .env and fill in your values.
# Never commit your real .env to git!

# Flask secret key (generate a strong random string)
SECRET_KEY=change-me-to-something-random-and-long

# Database URL
# SQLite (local dev):
DATABASE_URL=sqlite:///bbms_local.db
# TiDB / MySQL (production):
# DATABASE_URL=mysql+pymysql://USER:PASS@HOST:PORT/DBNAME

# Set to true to echo SQL queries (dev only)
SQLALCHEMY_ECHO=false

# Optional: Flask environment
FLASK_ENV=production
FLASK_DEBUG=0
